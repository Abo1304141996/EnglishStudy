# 英语抽认卡后端配置
# 复制此文件为 .env 并按需修改

# 服务配置
HOST=0.0.0.0
PORT=8888
DEBUG=true

# 存储后端: json (默认) | postgres (后续)
STORAGE_BACKEND=json

# 数据目录
DATA_DIR=./data

# 日志级别
LOG_LEVEL=INFO

# === 豆包 LLM 配置（通过 arkitect） ===
ARK_API_KEY=your_ark_api_key_here
ARK_LLM_ENDPOINT=ep-xxxxxxxxxxxx

# === 豆包流式 ASR（语音识别大模型）配置 ===
ASR_APP_ID=your_asr_app_id
ASR_ACCESS_TOKEN=your_asr_access_token
ASR_SECRET_KEY=your_asr_secret_key
ASR_RESOURCE_ID=volc.bigasr.sauc.duration
ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel

# === OpenAI 兼容 TTS（gpt-4o-mini-tts 代理）===
OPENAI_BASE_URL=https://cn.gptapi.asia/v1
OPENAI_API_KEY=sk-xxxxxxxxxxxx
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TTS_FORMAT=mp3
